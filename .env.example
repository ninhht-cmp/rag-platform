# ════════════════════════════════════════════════════════════════
# RAG Platform — Environment Configuration
# Copy to .env and fill in required values before running.
# Generate SECRET_KEY: openssl rand -hex 32
# ════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────
APP_NAME=RAG Platform
APP_VERSION=1.0.0
ENVIRONMENT=local                   # local | staging | production
DEBUG=false
SECRET_KEY=                         # REQUIRED — min 32 chars
ALLOWED_HOSTS=["*"]
API_PREFIX=/api/v1

# ── LLM ──────────────────────────────────────────────────────────
# options: anthropic | openai | local
LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=                  # required if LLM_PROVIDER=anthropic
OPENAI_API_KEY=                     # required if LLM_PROVIDER=openai

LLM_MODEL_PRIMARY=claude-sonnet-4-6
LLM_MODEL_SECONDARY=claude-haiku-4-5-20251001
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
LLM_DAILY_BUDGET_USD=50.0

# ── Embedding ────────────────────────────────────────────────────
# Local model (default, no API key needed):
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# OpenAI embedding (fallback for machines without torch, e.g. Intel Mac):
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSION=1536

EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu                # cpu | cuda | mps

# ── Qdrant ───────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=                     # leave empty for local Qdrant (no auth)
QDRANT_TIMEOUT=30

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=1800              # seconds — agent conversation memory
REDIS_SEMANTIC_CACHE_TTL=86400      # seconds — semantic cache TTL

# ── PostgreSQL ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://rag:rag_dev_only@localhost:5432/rag_platform
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── RAG pipeline ─────────────────────────────────────────────────
# NOTE: These are global defaults. Each plugin in app/plugins/__init__.py
# defines its own RetrievalConfig and overrides these values per use-case.
# Changing these does NOT automatically affect existing plugin configs.
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.3             # 0.3 works well for OpenAI/BGE; raise to 0.7 for cosine-trained models
RAG_RERANKER_ENABLED=false          # requires sentence-transformers — disable on CPU-only envs
RAG_HYBRID_SEARCH=true
RAG_BM25_WEIGHT=0.3
RAG_SEMANTIC_WEIGHT=0.7

# ── Auth ─────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Observability (Langfuse) ─────────────────────────────────────
# NOTE: Langfuse integration is configured in Settings but not yet wired
# into llm_service.py or pipeline.py. Set LANGFUSE_ENABLED=false until implemented.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

LOG_LEVEL=INFO
LOG_FORMAT=console                  # console | json

# ── Evaluation (RAGAS) ───────────────────────────────────────────
# NOTE: RAGAS thresholds are configured in Settings but the eval service
# reads thresholds from each plugin's EvalThresholds config, not these values.
# These act as documentation/reference for the per-plugin defaults.
RAGAS_EVAL_ENABLED=false
RAGAS_MIN_FAITHFULNESS=0.82
RAGAS_MIN_RELEVANCY=0.78
RAGAS_MIN_CONTEXT_RECALL=0.75

# ── Feature flags ────────────────────────────────────────────────
# FEATURE_SEMANTIC_CACHE: actively used in pipeline.py
# FEATURE_STREAMING, FEATURE_AGENT_TOOLS, FEATURE_CITATION: defined in Settings
# but not yet read in application code — reserved for future use.
FEATURE_STREAMING=true
FEATURE_AGENT_TOOLS=true
FEATURE_SEMANTIC_CACHE=true
FEATURE_CITATION=true

# ── Slack Bot ─────────────────────────────────────────────────────
# Setup guide: xem SLACK_SETUP.md
#
# SLACK_BOT_TOKEN:      Slack App → OAuth & Permissions → Bot User OAuth Token (xoxb-...)
# SLACK_SIGNING_SECRET: Slack App → Basic Information → Signing Secret
# SLACK_APP_TOKEN:      Slack App → Basic Information → App-Level Tokens (xapp-...) [Socket Mode only]
#
# Sau khi bật SLACK_ENABLED=true, server sẽ expose:
#   POST /api/v1/slack/events    ← điền vào Event Subscriptions > Request URL
#   POST /api/v1/slack/commands  ← điền vào Slash Commands > Request URL
SLACK_ENABLED=false
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_SIGNING_SECRET=your-signing-secret-here
SLACK_APP_TOKEN=                            # optional: chỉ cần cho Socket Mode

# ── Docker Compose only ──────────────────────────────────────────
# These are used by docker-compose.yml, not the Python app.
POSTGRES_PASSWORD=rag_dev_only      # change before any non-local deployment
LANGFUSE_NEXTAUTH_SECRET=           # required if running Langfuse container
LANGFUSE_SALT=                      # required if running Langfuse container
