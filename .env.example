# ── App ──────────────────────────────────────────────────────────
APP_NAME=RAG Platform
APP_VERSION=1.0.0
ENVIRONMENT=local
DEBUG=true

# REQUIRED: generate with: openssl rand -hex 32
SECRET_KEY=

ALLOWED_HOSTS=["*"]
API_PREFIX=/api/v1

# ── LLM ──────────────────────────────────────────────────────────
# options: openai | anthropic | local
LLM_PROVIDER=openai

# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# https://platform.openai.com → API Keys
OPENAI_API_KEY=

LLM_MODEL_PRIMARY=gpt-4o-mini
LLM_MODEL_SECONDARY=gpt-4o-mini
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
LLM_DAILY_BUDGET_USD=5.0

# ── Embedding ────────────────────────────────────────────────────
# OpenAI embedding — fallback for Intel Mac (no torch)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu

# ── Qdrant ───────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_TIMEOUT=30

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=1800
REDIS_SEMANTIC_CACHE_TTL=86400

# ── PostgreSQL ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://rag:rag_dev_only@localhost:5432/rag_platform
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── RAG ──────────────────────────────────────────────────────────
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5
# Lowered from 0.7 — OpenAI cosine scores are typically 0.3-0.6 for relevant docs
RAG_SCORE_THRESHOLD=0.3
RAG_RERANKER_ENABLED=false
RAG_HYBRID_SEARCH=true
RAG_BM25_WEIGHT=0.3
RAG_SEMANTIC_WEIGHT=0.7

# ── Auth ─────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Observability ────────────────────────────────────────────────
# Get keys from: https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=false

LOG_LEVEL=INFO
# options: console | json
LOG_FORMAT=console

# ── Evaluation ───────────────────────────────────────────────────
RAGAS_EVAL_ENABLED=false
RAGAS_MIN_FAITHFULNESS=0.82
RAGAS_MIN_RELEVANCY=0.78
RAGAS_MIN_CONTEXT_RECALL=0.75

# ── Feature flags ────────────────────────────────────────────────
FEATURE_STREAMING=true
FEATURE_AGENT_TOOLS=false
FEATURE_SEMANTIC_CACHE=true
FEATURE_CITATION=true

# ── Docker Compose ───────────────────────────────────────────────
# Change these before deploying to production
POSTGRES_PASSWORD=rag_dev_only
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
